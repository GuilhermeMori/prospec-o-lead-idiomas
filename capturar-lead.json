      "parameters": {
        "jsCode": "const url = $input.first().json.body[\"URL da página\"]\n\nconst utmSourceRegex = /utm_source=([^&]+)/;\nconst utmSourceMatch = url.match(utmSourceRegex);\nconst utmSource = utmSourceMatch ? utmSourceMatch[1] : null;\n\nconst utmMediumRegex = /utm_medium=([^&]+)/;\nconst utmMediumMatch = url.match(utmMediumRegex);\nconst utmMedium = utmMediumMatch ? decodeURIComponent(utmMediumMatch[1]) : null;\n\nconst utmCampaignRegex = /utm_campaign=([^&]+)/;\nconst utmCampaignMatch = url.match(utmCampaignRegex);\nconst utmCampaign = utmCampaignMatch ? decodeURIComponent(utmCampaignMatch[1]) : null;\n\nconst utmTermRegex = /utm_term=([^&]+)/;\nconst utmTermMatch = url.match(utmTermRegex);\nconst utmTerm = utmTermMatch ? decodeURIComponent(utmTermMatch[1]) : null;\n\nreturn {utmSource, utmMedium, utmCampaign, utmTerm};"
      },
