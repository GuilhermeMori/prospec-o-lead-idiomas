    {
      "parameters": {
        "jsCode": "const idioma = $node[\"Formulario - Site9\"].json.body[\"mauticform[idioma]\"]?.toLowerCase?.() || 'ingles';\nconst nome = $node[\"Formulario - Site9\"].json.body[\"mauticform[nome]\"];\nconst empresa = $node[\"Formulario - Site9\"].json.body[\"mauticform[company]\"];\n\nlet content = '';\n\nswitch (idioma) {\n  case 'ingles':\n    content = `Hi ${nome}, how are you? 😊\\nI'm the support bot from ${empresa}. I received your message through our website and I'm already transferring it to our team. 🚀\\nIn the meantime, could you tell us a bit more about what you're looking for? That way, we can help you in a much more personalized way!`;\n    break;\n\n  case 'espanhol':\n    content = `Hola ${nome}, ¿cómo estás? 😊\\nSoy el bot de atención de ${empresa}. Recibí tu mensaje a través de nuestro sitio web y ya lo estoy transfiriendo a nuestro equipo. 🚀\\nMientras tanto, ¿podrías contarnos un poco más sobre lo que estás buscando? ¡Así podremos ayudarte de una forma mucho más personalizada!`;\n    break;\n\n  case 'frances':\n    content = `Bonjour ${nome}, comment ça va ? 😊\\nJe suis le bot de support de ${empresa}. J'ai reçu votre message via notre site web et je le transfère déjà à notre équipe. 🚀\\nEn attendant, pourriez-vous nous en dire un peu plus sur ce que vous recherchez ? Cela nous aidera à vous accompagner de manière plus personnalisée !`;\n    break;\n\n  case 'alemao':\n    content = `Hallo ${nome}, wie geht es dir? 😊\\nIch bin der Support-Bot von ${empresa}. Ich habe deine Nachricht über unsere Website erhalten und leite sie bereits an unser Team weiter. 🚀\\nIn der Zwischenzeit könntest du uns ein bisschen mehr darüber erzählen, wonach du suchst? So können wir dir viel persönlicher helfen!`;\n    break;\n\n  case 'italiano':\n    content = `Ciao ${nome}, come stai? 😊\\nSono il bot di supporto di ${empresa}. Ho ricevuto il tuo messaggio tramite il nostro sito web e lo sto già trasferendo al nostro team. 🚀\\nNel frattempo, potresti dirci qualcosa in più su ciò che stai cercando? Così potremo aiutarti in modo molto più personalizzato!`;\n    break;\n\n  default:\n    content = `Hi ${nome}, how are you? 😊\\nI'm the support bot from ${empresa}. I received your message through our website and I'm already transferring it to our team. 🚀\\nIn the meantime, could you tell us a bit more about what you're looking for? That way, we can help you in a much more personalized way!`;\n    break;\n}\n\nreturn [\n  {\n    json: {\n      content\n    }\n  }\n];\n"
      },
