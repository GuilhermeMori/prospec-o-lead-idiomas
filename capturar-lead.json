      "parameters": {
        "jsCode": "const agora = new Date();\nconst mes = agora.getMonth(); \n\nconst marcadores = [\n  { mes: \"jan\", marcador: \"jan-25\" },\n  { mes: \"fev\", marcador: \"fev-25\" },\n  { mes: \"mar\", marcador: \"mar-25\" },\n  { mes: \"abr\", marcador: \"abr-25\" },\n  { mes: \"mai\", marcador: \"mai-25\" },\n  { mes: \"jun\", marcador: \"jun-25\" },\n  { mes: \"jul\", marcador: \"jul-25\" },\n  { mes: \"ago\", marcador: \"ago-25\" },\n  { mes: \"set\", marcador: \"set-25\" },\n  { mes: \"out\", marcador: \"out-25\" },\n  { mes: \"nov\", marcador: \"nov-25\" },\n  { mes: \"dez\", marcador: \"dez-25\" }\n];\n\nreturn {\n  json: {\n    marcador: marcadores[mes].marcador\n  }\n};\n"
      },
