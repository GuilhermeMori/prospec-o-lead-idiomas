      "parameters": {
        "jsCode": "const ddiMap = {\n  espanhol: \"+595\",\n  ingles: \"+44\",\n  frances: \"+33\",\n  alemao: \"+49\"\n};\n\nreturn items.map(item => {\n  let telefone = $('limpar telefone').first().json.telefone_limpo;\n  const idioma = ($('Formulario - Site9').first().json.body[\"mauticform[idioma]\"] || \"\").toLowerCase();\n\n  const e164Regex = /^\\+[1-9]\\d{9,14}$/;\n\n  if (!e164Regex.test(telefone)) {\n    telefone = telefone.replace(/\\D/g, \"\");\n    const ddi = ddiMap[idioma] || \"+55\";\n    if (ddi && !telefone.startsWith(ddi.replace(\"+\", \"\"))) {\n      telefone = ddi + telefone;\n    }\n  }\n\n  item.json[\"mauticform[telefone]\"] = telefone;\n  return item;\n});\n"
      },
